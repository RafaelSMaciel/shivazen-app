# ShivaZen — Variaveis de Ambiente
# Copie este arquivo para `.env` e ajuste os valores.

# ───────────────────────────────────────────────
# Django Core
# ───────────────────────────────────────────────
# Em producao, DJANGO_SECRET_KEY e obrigatoria. Gere com:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=troque-essa-chave-em-producao

# DEBUG=True apenas em dev local. Em producao, NUNCA defina como True.
DEBUG=True

# Dominio da aplicacao (separar por virgula). Railway adiciona RAILWAY_PUBLIC_DOMAIN automaticamente.
ALLOWED_HOSTS=127.0.0.1,localhost

# Origens confiaveis CSRF (https em producao)
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# Em producao HTTPS, defina True
USE_HTTPS=False

# Selecao de settings module (base|dev|prod). Vazio => dev.
DJANGO_ENV=dev

# ───────────────────────────────────────────────
# Banco de Dados
# ───────────────────────────────────────────────
# Producao: Railway define DATABASE_URL automaticamente.
# Dev local: se nao definir DATABASE_URL, usa SQLite (db_dev.sqlite3).
# DATABASE_URL=postgres://user:pass@localhost:5432/shivazen_dev

# Alternativa manual (sem DATABASE_URL):
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=shivazen_dev
# DB_USER=postgres
# DB_PASSWORD=
# DB_HOST=localhost
# DB_PORT=5432

# ───────────────────────────────────────────────
# Cache / Sessoes / Celery (Redis)
# ───────────────────────────────────────────────
# Em dev: vazio => LocMemCache + sessao em DB.
# Em producao: use Redis (Railway Redis fornece REDIS_URL).
REDIS_URL=
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ───────────────────────────────────────────────
# Email (recuperacao de senha, lembretes)
# ───────────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@clinica.com.br

# ───────────────────────────────────────────────
# White-label / Marca (context_processors.py)
# ───────────────────────────────────────────────
CLINIC_NAME=Shiva Zen
CLINIC_TAGLINE=Estetica & Bem-Estar
CLINIC_EMAIL=contato@clinica.com.br
CLINIC_PHONE=+5511999999999
CLINIC_WHATSAPP=+5511999999999
CLINIC_INSTAGRAM=
CLINIC_ADDRESS=

# ───────────────────────────────────────────────
# Sentry (observabilidade opcional)
# ───────────────────────────────────────────────
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.2

# ───────────────────────────────────────────────
# WhatsApp Business API
# ───────────────────────────────────────────────
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=

# ───────────────────────────────────────────────
# Logging
# ───────────────────────────────────────────────
DJANGO_LOG_LEVEL=INFO
